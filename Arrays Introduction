#include <iostream>
using namespace std;

int main() {
    int n;
    // Read the size of the array
    cin >> n;

    // Declare the array with the input size
    int arr[n];

    // Read n integers into the array
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    // Print the elements in reverse order
    for (int i = n - 1; i >= 0; i--) {
        cout << arr[i] << (i == 0 ? "" : " ");
    }

    return 0;
}
