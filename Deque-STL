#include <iostream>
#include <deque> 
using namespace std;

void printKMax(int arr[], int n, int k){
	std::deque<int> dq;

    for (int i = 0; i < n; i++) {
        // 1. Remove elements out of this window
        if (!dq.empty() && dq.front() == i - k) {
            dq.pop_front();
        }

        // 2. Remove elements smaller than the current element from the back
        // because they will never be the maximum in this or any future window
        while (!dq.empty() && arr[i] >= arr[dq.back()]) {
            dq.pop_back();
        }

        // 3. Add current element's index to the back
        dq.push_back(i);

        // 4. The front of the deque is the index of the largest element
        // We start printing once we've reached the first full window (index k-1)
        if (i >= k - 1) {
            cout << arr[dq.front()] << (i == n - 1 ? "" : " ");
        }
    }
    cout << endl;
//Write your code here.
}

int main(){
  
	int t;
	cin >> t;
	while(t>0) {
		int n,k;
    	cin >> n >> k;
    	int i;
    	int arr[n];
    	for(i=0;i<n;i++)
      		cin >> arr[i];
    	printKMax(arr, n, k);
    	t--;
  	}
  	return 0;
}
