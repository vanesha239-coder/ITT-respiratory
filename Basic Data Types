#include <iostream>
#include <cstdio>
using namespace std;

int main() {
    {
        int a;
        long b;
        char c;
        float d;
        double s;
        scanf("%d %ld %c %f %lf",&a,&b,&c,&d,&s);
        printf("%d\n",a);
        printf("%ld\n",b);
        printf("%c\n",c);
        printf("%f\n",d);
        printf("%lf\n",s);
    }
    return 0;
}
