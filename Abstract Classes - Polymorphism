using namespace std;

struct Node{
   Node* next;
   Node* prev;
   int value;
   int key;
   Node(Node* p, Node* n, int k, int val):prev(p),next(n),key(k),value(val){};
   Node(int k, int val):prev(NULL),next(NULL),key(k),value(val){};
};

class Cache{
   
   protected: 
   map<int,Node*> mp; //map the key to the node in the linked list
   int cp;  //capacity
   Node* tail; // double linked list tail pointer
   Node* head; // double linked list head pointer
   virtual void set(int, int) = 0; //set function
   virtual int get(int) = 0; //get function

};
class LRUCache : public Cache {
public:
    LRUCache(int capacity) { cp = capacity; head = tail = NULL; }

    void set(int key, int val) override {
        if (mp.find(key) != mp.end()) {
            // Update value and move to head
            Node* node = mp[key];
            node->value = val;
            moveToHead(node);
        } else {
            Node* newNode = new Node(NULL, head, key, val);
            if (head) head->prev = newNode;
            head = newNode;
            if (!tail) tail = head;
            
            if (mp.size() >= cp) {
                // Evict tail
                mp.erase(tail->key);
                Node* temp = tail;
                tail = tail->prev;
                if (tail) tail->next = NULL;
                delete temp;
            }
            mp[key] = newNode;
        }
    }

    int get(int key) override {
        if (mp.find(key) == mp.end()) return -1;
        moveToHead(mp[key]);
        return mp[key]->value;
    }

private:
    void moveToHead(Node* node) {
        if (node == head) return;
        if (node == tail) {
            tail = tail->prev;
            tail->next = NULL;
        } else {
            node->prev->next = node->next;
            node->next->prev = node->prev;
        }
        node->next = head;
        node->prev = NULL;
        head->prev = node;
        head = node;
    }
};
int main() {
   int n, capacity,i;
   cin >> n >> capacity;
   LRUCache l(capacity);
   for(i=0;i<n;i++) {
      string command;
      cin >> command;
      if(command == "get") {
         int key;
         cin >> key;
         cout << l.get(key) << endl;
      } 
      else if(command == "set") {
         int key, value;
         cin >> key >> value;
         l.set(key,value);
      }
   }
   return 0;
}
